# ============================================================
# .env — Copy this file, rename to .env, fill in your values
# NEVER commit .env to git
# ============================================================

# ── Discord ──────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# Right-click each channel in Discord → Copy Channel ID
# (Enable Developer Mode: Settings → Advanced → Developer Mode)
CHANNEL_CALLOUTS=000000000000000000
CHANNEL_HIGH_CONF=000000000000000000
CHANNEL_FLOW=000000000000000000

# ── Optional Overrides ───────────────────────────────────────
# (these have defaults in settings.py — only set if you want to override)
# MIN_OPEN_INTEREST=500
# FLOW_MIN_PREMIUM=50000
# HIGH_CONF_THRESHOLD=0.75
# RISK_FREE_RATE=0.045
